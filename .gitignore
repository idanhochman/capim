# Python cruft only -- source, tests, docs, and the sd_repos/ submodules are tracked.
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
*.egg-info/
.venv/
venv/

# collected traces + simulation outputs (regenerated from the collect/drive runs)
traces/
results/

# editor/OS
*.swp
*.swo
.DS_Store
*:Zone.Identifier

# doc
doc/main.*
